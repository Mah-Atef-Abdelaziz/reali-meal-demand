# ============================================================
# REAL.i Meal Demand AI — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# App
APP_NAME="REAL.i Meal Demand AI"
APP_VERSION="1.0.0"
DEBUG=true
API_PREFIX="/api/v1"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Database (PostgreSQL)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/meal_demand"
DATABASE_SYNC_URL="postgresql://postgres:postgres@localhost:5432/meal_demand"

# Redis
REDIS_URL="redis://localhost:6379/0"

# JWT Authentication
JWT_SECRET_KEY="change-this-to-a-secure-random-string-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI (primary LLM)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Ollama (fallback LLM — local, free)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"
USE_LOCAL_LLM=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL="INFO"
